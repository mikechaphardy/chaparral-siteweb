---
import Base from '../layouts/Base.astro';
---
<Base current="legals" locale="en" path="/legals" bodyClass="antialiased flex flex-col min-h-screen overflow-x-hidden bg-[#0A1A2A]">

<Fragment slot="head">
<title>Legal Notice and Data Protection Policy - Chaparral Finance</title>
  <meta name="description" content="Legal notice, terms of use and data protection policy of the Chaparral Finance website.">
  <link rel="canonical" href="https://www.chaparral-finance.com/legals">
  

  <!-- Open Graph / Social Media -->
  <meta property="og:title" content="Legal Notice and Data Protection Policy - Chaparral Finance">
  <meta property="og:description" content="Legal notice, terms of use and data protection policy of the Chaparral Finance website.">
  <meta property="og:url" content="https://www.chaparral-finance.com/legals">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://res.cloudinary.com/drncmlu30/image/upload/v1766653300/Airbrush-OBJECT-REMOVER-1766652971579_qx1gwx.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Chaparral Finance - Mentions Légales">

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Legal Notice and Data Protection Policy - Chaparral Finance">
  <meta name="twitter:description" content="Legal notice, terms of use and data protection policy of the Chaparral Finance website.">
  <meta name="twitter:image" content="https://res.cloudinary.com/drncmlu30/image/upload/v1766653300/Airbrush-OBJECT-REMOVER-1766652971579_qx1gwx.png">

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Legal Notice and Data Protection Policy - Chaparral Finance",
      "url": "https://www.chaparral-finance.com/legals",
      "isPartOf": {
        "@type": "WebSite",
        "name": "Chaparral Finance",
        "url": "https://www.chaparral-finance.com/"
      }
    }
  </script>
</Fragment>

<Fragment slot="styles">
<style is:inline>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #0A1A2A;
      color: #D3D3B9;
    }
    h1, h2, h3, h4, .serif {
      font-family: 'Playfair Display', serif;
    }
    /* Smooth scrolling */
    html { scroll-behavior: smooth; }
    
    /* Navigation transition state */
    body.nav-transitioning header {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      background-color: #0A1A2A !important;
    }
    /* Page transition overlay */
    #page-transition-overlay {
      position: fixed;
      inset: 0;
      background-color: #0A1A2A;
      z-index: 9999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease-out;
    }
    body.nav-transitioning #page-transition-overlay {
      opacity: 1;
      pointer-events: all;
    }
    
    /* Page Load Animation */
    body { opacity: 0; transition: opacity 0.6s ease-out; }
    body.loaded { opacity: 1; }

    /* Mobile Menu Transition */
    #mobile-menu {
      transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    }
  </style>
</Fragment>


  <!-- MAIN CONTENT: LEGAL MENTIONS -->
  <main class="flex-grow pt-16 pb-32">
    <div class="md:px-12 max-w-4xl mx-auto px-6">

      <!-- Header -->
      <div class="mb-16 border-b border-white/10 pb-12">
        <h1 class="serif md:text-5xl text-3xl font-medium text-white tracking-tight mb-6">Legal Notice and Data Protection Policy</h1>
        <p class="text-lg font-light text-[#D3D3B9]/80">
          Legal notice, terms of use and data protection policy.
        </p>
      </div>

      <!-- Legal Content -->
      <div class="space-y-12 text-[#D3D3B9]/90 font-light leading-relaxed">

        <section>
          <h2 class="text-2xl font-medium text-white mb-6 serif">LEGAL NOTICE AND DATA PROTECTION POLICY</h2>
          <p class="mb-4 font-medium text-white/80">In force as of 5 January 2026</p>
          <p class="mb-4">
            In accordance with Articles 6-III and 19 of French Law No. 2004-575 of 21 June 2004 on Confidence in the Digital Economy (known as L.C.E.N.), users and visitors, hereinafter the "User", of the website https://www.chaparral-finance.com/, hereinafter the "Site", are hereby informed of the present legal notice.
          </p>
          <p class="mb-4">
            Connection to and browsing of the Site by the User implies full and unreserved acceptance of this legal notice, which is accessible on the Site under the "Legal notice" section. This English version is provided for convenience; in the event of any discrepancy, the French version prevails.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 1 - PUBLISHER</h3>
          <p class="mb-4">
            The Site is published and its publication directed by CHAPARRAL FINANCE SAS, trading under the name Chaparral Finance.
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>Legal form:</strong> Société par Actions Simplifiée (simplified joint-stock company)</li>
            <li><strong>Share capital:</strong> EUR 100,000.00</li>
            <li><strong>Paris Trade and Companies Register (RCS):</strong> XXX XXX XXX</li>
            <li><strong>Registered office:</strong> 25 rue du Général Foy, 75008 Paris, France</li>
            <li><strong>Email address:</strong> contact@chaparral-finance.fr</li>
            <li><strong>Publication director:</strong> Mr Maxime Dugast, President</li>
          </ul>
          <p class="mb-4">
            The company does not carry out any regulated activity subject to specific authorisation / registration (AMF/ACPR).
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 2 - HOSTING PROVIDER</h3>
          <p class="mb-4">The Site is hosted by:</p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>Company name:</strong> Vercel Inc.</li>
            <li><strong>Address:</strong> 650 California St, San Francisco, CA 94108, United States</li>
            <li><strong>Website:</strong> https://vercel.com</li>
            <li><strong>Technical note:</strong> Design and development by DEVINOTEK SAS</li>
          </ul>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 3 - ACCESS TO THE SITE AND LIABILITY</h3>
          <p class="mb-4">
            The Site is accessible from anywhere, 7 days a week, 24 hours a day, except in cases of force majeure or scheduled or unscheduled interruption that may result from maintenance requirements. The Publisher shall not be held liable in the event of modification, interruption or suspension of the Site's services.
          </p>
          <p class="mb-4">
            <strong>Limitation of liability regarding financial information:</strong> The information provided on the Site is for information purposes only. It does not exempt the User from carrying out additional, personalised analysis. Chaparral Finance cannot guarantee the accuracy, completeness or currency of the information published on the Site. Consequently, the User acknowledges that they use this information under their sole responsibility. Chaparral Finance shall not be held liable for any direct or indirect damage, such as financial losses, loss of profits or loss of opportunities, resulting from the use of the Site or the inability to access it.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 4 - REGULATORY DISCLAIMER (MIFID II / AMF)</h3>
          <p class="mb-4"><strong>4.1 No public offering</strong></p>
          <p class="mb-4">
            The content of this Site does not in any way constitute a public offering of financial securities, a solicitation, banking or financial canvassing, or a recommendation to buy or sell financial instruments within the meaning of Article L.411-1 of the French Monetary and Financial Code and the General Regulation of the AMF (French financial markets authority).
          </p>
          <p class="mb-4"><strong>4.2 Nature of the services</strong></p>
          <p class="mb-4">
            Unless explicitly stated otherwise, the services presented on this Site fall within the scope of corporate strategy consulting and financial engineering ("Corporate Finance"). The use of the term "Investment Bank" on the Site is to be understood in its usual economic sense of an "M&A advisory boutique" and shall not be construed as a claim to the status of credit institution within the meaning of Article L.511-1 of the French Monetary and Financial Code. Chaparral Finance does not receive funds from the public and does not grant credit. Chaparral Finance does not carry out the activity of financial investment adviser within the meaning of Article L.541-1 of the French Monetary and Financial Code.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 5 - INTELLECTUAL PROPERTY</h3>
          <p class="mb-4">
            The Publisher is the exclusive owner of all intellectual property rights, or holds the rights of use, over all elements accessible on the Site, including its structure, texts, images, graphics, logo, icons, sounds and software.
          </p>
          <p class="mb-4">
            Any reproduction, representation, modification, publication or adaptation of all or part of the elements of the Site, by any means or process whatsoever, is prohibited without the prior written authorisation of the Publisher, in accordance with Articles L.335-2 et seq. of the French Intellectual Property Code.
          </p>
          <p class="mb-4">
            The trademarks mentioned (in particular those of clients or partners in the "Track Record" or "Transactions" section) are the property of their respective owners. Their display on the Site does not imply any permanent legal relationship between Chaparral Finance and these entities beyond the engagements carried out.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 6 - GOVERNING LAW AND JURISDICTION</h3>
          <p class="mb-4">
            This legal notice is governed by French law. In the event of a dispute and failing amicable agreement, the dispute shall be brought before the competent courts within the jurisdiction of the Paris Court of Appeal, notwithstanding multiple defendants or third-party claims.
          </p>
        </section>

        <div class="w-full h-px bg-white/10 my-16"></div>

        <section id="privacy">
          <h2 class="text-2xl font-medium text-white mb-6 serif">ARTICLE 7 - PERSONAL DATA PROTECTION POLICY</h2>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">1. Preamble and Commitment</h3>
          <p class="mb-4">
            Chaparral Finance is committed to ensuring that the collection and processing of your data, carried out from the chaparral-finance.com website, comply with the General Data Protection Regulation (GDPR) and the French Data Protection Act. Chaparral Finance ensures in particular compliance with the principles of lawfulness, fairness, transparency, data minimisation, limitation of retention periods and security of processing, in accordance with Article 5 of the GDPR.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">2. Identity of the Data Controller</h3>
          <p class="mb-4">
            The data controller is CHAPARRAL FINANCE, located at 25, rue du Général Foy, 75008 Paris, represented by its President.
          </p>
          <p class="mb-4">
            The company has not appointed a Data Protection Officer (DPO), as it is not legally required to do so given the nature of its processing activities.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">3. Data Collected and Purposes</h3>
          <p class="mb-4">
            Chaparral Finance ensures that the data collected is adequate, relevant and limited to what is strictly necessary in view of the purposes pursued.
          </p>

          <div class="space-y-4">
            <div>
              <p class="font-medium text-white/90">Identity and professional contact details (surname, first name, professional email, telephone number)</p>
              <ul class="list-disc pl-5 mt-2 space-y-1 text-white/70 text-sm">
                <li><strong>Purpose:</strong> processing of requests submitted via the contact form, scheduling of meetings and pre-contractual exchanges.</li>
                <li><strong>Legal basis:</strong> performance of pre-contractual measures taken at the request of the data subject (Article 6(1)(b) GDPR).</li>
              </ul>
            </div>

            <div>
              <p class="font-medium text-white/90">Browsing data (IP address, cookies, technical logs)</p>
              <ul class="list-disc pl-5 mt-2 space-y-1 text-white/70 text-sm">
                <li><strong>Purpose:</strong> audience measurement, improvement of the operation of the site and security of information systems.</li>
                <li><strong>Legal basis:</strong>
                  <ul class="list-circle pl-5 mt-1">
                    <li>the user's consent for cookies that are not strictly necessary;</li>
                    <li>the legitimate interest of Chaparral Finance in the security of the site and the prevention of abuse (Article 6(1)(f) GDPR).</li>
                  </ul>
                </li>
              </ul>
            </div>
          </div>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">4. Retention Period</h3>
          <p class="mb-4">
            Personal data relating to prospects is kept for a maximum of three (3) years from the last active contact initiated by the data subject (request for information, contact, email exchange or confirmed interaction).
          </p>
          <p class="mb-4">
            Technical browsing data is kept for a period not exceeding what is strictly necessary for security and audience measurement purposes.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">5. Recipients and Data Transfers</h3>
          <p class="mb-4">
            The personal data collected is intended exclusively for the authorised partners and employees of Chaparral Finance, within the limits of their respective duties.
          </p>
          <p class="mb-4">
            Data may also be processed by technical service providers (in particular hosting, maintenance or IT tools), acting as processors within the meaning of the GDPR and subject to contractual confidentiality and security obligations.
          </p>
          <p class="mb-4">
            The data is hosted within the European Union. Should data be transferred outside the European Union, such transfer would be governed by appropriate safeguards, in particular the standard contractual clauses adopted by the European Commission, in accordance with Articles 44 et seq. of the GDPR.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">6. Your Data Protection Rights</h3>
          <p class="mb-4">
            In accordance with the applicable regulations, you have the rights of access, rectification, erasure, restriction, objection and portability of your personal data.
          </p>
          <p class="mb-4">
            Where processing is based on your consent, you may withdraw it at any time, without affecting the lawfulness of the processing based on consent carried out prior to such withdrawal.
          </p>
          <p class="mb-4">
            Where processing is based on the legitimate interest of Chaparral Finance, you have the right to object to it at any time on grounds relating to your particular situation.
          </p>
          <p class="mb-4">
            The data marked as mandatory in the forms is required to process your request; failing to provide it, Chaparral Finance may not be able to respond.
          </p>
          <p class="mb-4">
            Cookies are managed via a consent management tool accessible on the first visit to the Site and at any time thereafter. The User may thus accept, refuse or configure the use of cookies in accordance with the applicable regulations.
          </p>
          <p class="mb-4">
            To exercise your rights, you may contact Chaparral Finance:
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>By email:</strong> <a href="mailto:contact@chaparral-finance.fr" class="text-white hover:underline">contact@chaparral-finance.fr</a></li>
            <li><strong>By post:</strong> 25, rue du Général Foy, 75008 Paris</li>
          </ul>
          <p class="mb-4">
            If, after contacting us, you consider that your rights have not been respected, you may lodge a complaint with the French data protection authority (Commission Nationale de l'Informatique et des Libertés - CNIL).
          </p>
        </section>

      </div>
    </div>
  </main>

  <!-- Footer -->

<Fragment slot="scripts">

  <script is:inline>
    lucide.createIcons();

    // Initial Load Animation
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        document.body.classList.add('loaded');
      });
    } else {
      document.body.classList.add('loaded');
    }

    // Page transition
    function initPageTransition() {
      document.querySelectorAll('a[href]').forEach(link => {
        const href = link.getAttribute('href') || '';
        
        if (link.hostname !== window.location.hostname) return;
        if (link.hasAttribute('target')) return;
        if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
        
        link.addEventListener('click', (e) => {
          e.preventDefault();
          document.body.classList.add('nav-transitioning');
          setTimeout(() => {
            window.location.href = href;
          }, 150);
        });
      });
      
      window.addEventListener('beforeunload', () => {
        document.body.classList.add('nav-transitioning');
      });
      
      window.addEventListener('pageshow', (e) => {
        if (e.persisted) {
          document.body.classList.remove('nav-transitioning');
        }
      });
    }
    
    document.body.classList.remove('nav-transitioning');
    initPageTransition();

    // Mobile Menu
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');

    function openMenu() { menu.classList.remove('translate-x-full'); }
    function closeMenu() { menu.classList.add('translate-x-full'); }

    if (menuBtn) menuBtn.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);

    const mobileLinks = document.querySelectorAll('.mobile-link');
    mobileLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  </script>
</Fragment>

</Base>
