---
import Base from '../../layouts/Base.astro';
---
<Base current="legals" locale="it" path="/legals" bodyClass="antialiased flex flex-col min-h-screen overflow-x-hidden bg-[#0A1A2A]">

<Fragment slot="head">
<title>Note Legali e Politica di Protezione dei Dati - Chaparral Finance</title>
  <meta name="description" content="Note legali, condizioni generali di utilizzo e politica di protezione dei dati del sito Chaparral Finance.">
  <link rel="canonical" href="https://www.chaparral-finance.com/it/legals">
  

  <!-- Open Graph / Social Media -->
  <meta property="og:title" content="Note Legali e Politica di Protezione dei Dati - Chaparral Finance">
  <meta property="og:description" content="Note legali, condizioni generali di utilizzo e politica di protezione dei dati del sito Chaparral Finance.">
  <meta property="og:url" content="https://www.chaparral-finance.com/it/legals">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://res.cloudinary.com/drncmlu30/image/upload/v1766653300/Airbrush-OBJECT-REMOVER-1766652971579_qx1gwx.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Chaparral Finance - Mentions Légales">

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Note Legali e Politica di Protezione dei Dati - Chaparral Finance">
  <meta name="twitter:description" content="Note legali, condizioni generali di utilizzo e politica di protezione dei dati del sito Chaparral Finance.">
  <meta name="twitter:image" content="https://res.cloudinary.com/drncmlu30/image/upload/v1766653300/Airbrush-OBJECT-REMOVER-1766652971579_qx1gwx.png">

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Note Legali e Politica di Protezione dei Dati - Chaparral Finance",
      "url": "https://www.chaparral-finance.com/it/legals",
      "isPartOf": {
        "@type": "WebSite",
        "name": "Chaparral Finance",
        "url": "https://www.chaparral-finance.com/"
      }
    }
  </script>
</Fragment>

<Fragment slot="styles">
<style is:inline>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #0A1A2A;
      color: #D3D3B9;
    }
    h1, h2, h3, h4, .serif {
      font-family: 'Playfair Display', serif;
    }
    /* Smooth scrolling */
    html { scroll-behavior: smooth; }
    
    /* Navigation transition state */
    body.nav-transitioning header {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      background-color: #0A1A2A !important;
    }
    /* Page transition overlay */
    #page-transition-overlay {
      position: fixed;
      inset: 0;
      background-color: #0A1A2A;
      z-index: 9999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease-out;
    }
    body.nav-transitioning #page-transition-overlay {
      opacity: 1;
      pointer-events: all;
    }
    
    /* Page Load Animation */
    body { opacity: 0; transition: opacity 0.6s ease-out; }
    body.loaded { opacity: 1; }

    /* Mobile Menu Transition */
    #mobile-menu {
      transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    }
  </style>
</Fragment>


  <!-- MAIN CONTENT: LEGAL MENTIONS -->
  <main class="flex-grow pt-16 pb-32">
    <div class="md:px-12 max-w-4xl mx-auto px-6">

      <!-- Header -->
      <div class="mb-16 border-b border-white/10 pb-12">
        <h1 class="serif md:text-5xl text-3xl font-medium text-white tracking-tight mb-6">Note Legali e Politica di Protezione dei Dati</h1>
        <p class="text-lg font-light text-[#D3D3B9]/80">
          Note legali, condizioni generali di utilizzo e politica di protezione dei dati.
        </p>
      </div>

      <!-- Legal Content -->
      <div class="space-y-12 text-[#D3D3B9]/90 font-light leading-relaxed">

        <section>
          <h2 class="text-2xl font-medium text-white mb-6 serif">NOTE LEGALI E POLITICA DI PROTEZIONE DEI DATI</h2>
          <p class="mb-4 font-medium text-white/80">In vigore dal 5 gennaio 2026</p>
          <p class="mb-4">
            In conformità con gli articoli 6-III e 19 della legge francese n. 2004-575 del 21 giugno 2004 sulla fiducia nell'economia digitale (c.d. L.C.E.N.), si portano a conoscenza degli utenti e dei visitatori, di seguito l'"Utente", del sito https://www.chaparral-finance.com/, di seguito il "Sito", le presenti note legali.
          </p>
          <p class="mb-4">
            La connessione e la navigazione sul Sito da parte dell'Utente comportano l'accettazione integrale e senza riserve delle presenti note legali, accessibili sul Sito alla sezione "Note legali". La presente versione italiana è fornita a titolo informativo; in caso di divergenza, prevale la versione francese.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICOLO 1 - L'EDITORE</h3>
          <p class="mb-4">
            La pubblicazione e la direzione editoriale del Sito sono assicurate dalla società CHAPARRAL FINANCE SAS, operante con la denominazione commerciale Chaparral Finance.
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>Forma giuridica:</strong> Société par Actions Simplifiée (società per azioni semplificata di diritto francese)</li>
            <li><strong>Capitale sociale:</strong> 100.000,00 Euro</li>
            <li><strong>Registro delle imprese di Parigi (RCS):</strong> XXX XXX XXX</li>
            <li><strong>Sede legale:</strong> 25 rue du Général Foy, 75008 Parigi, Francia</li>
            <li><strong>Indirizzo e-mail:</strong> contact@chaparral-finance.fr</li>
            <li><strong>Direttore della pubblicazione:</strong> Sig. Maxime Dugast, Presidente</li>
          </ul>
          <p class="mb-4">
            La società non esercita alcuna attività regolamentata soggetta ad autorizzazione / iscrizione specifica (AMF/ACPR).
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICOLO 2 - L'HOSTING PROVIDER</h3>
          <p class="mb-4">L'hosting del Sito è assicurato dalla società:</p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>Ragione sociale:</strong> Vercel Inc.</li>
            <li><strong>Indirizzo:</strong> 650 California St, San Francisco, CA 94108, Stati Uniti</li>
            <li><strong>Sito web:</strong> https://vercel.com</li>
            <li><strong>Nota tecnica:</strong> Progettazione e sviluppo DEVINOTEK SAS</li>
          </ul>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICOLO 3 - ACCESSO AL SITO E RESPONSABILITÀ</h3>
          <p class="mb-4">
            Il Sito è accessibile da qualsiasi luogo, 7 giorni su 7, 24 ore su 24, salvo casi di forza maggiore o interruzioni, programmate o meno, derivanti da esigenze di manutenzione. In caso di modifica, interruzione o sospensione dei servizi del Sito, l'Editore non potrà essere ritenuto responsabile.
          </p>
          <p class="mb-4">
            <strong>Limitazione di responsabilità sulle informazioni finanziarie:</strong> le informazioni fornite sul Sito hanno carattere puramente informativo. Esse non esonerano l'Utente da un'analisi complementare e personalizzata. Chaparral Finance non può garantire l'esattezza, la completezza o l'attualità delle informazioni diffuse sul Sito. Di conseguenza, l'Utente riconosce di utilizzare tali informazioni sotto la propria esclusiva responsabilità. Chaparral Finance non potrà essere ritenuta responsabile dei danni diretti o indiretti, quali perdite finanziarie, mancati profitti o perdite di opportunità, derivanti dall'utilizzo del Sito o dall'impossibilità di accedervi.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICOLO 4 - AVVERTENZA REGOLAMENTARE (MIFID II / AMF)</h3>
          <p class="mb-4"><strong>4.1 Assenza di offerta al pubblico</strong></p>
          <p class="mb-4">
            Il contenuto di questo Sito non costituisce in alcun caso un'offerta al pubblico di titoli finanziari, una sollecitazione, un'attività di promozione bancaria o finanziaria, né una raccomandazione di acquisto o di vendita di strumenti finanziari ai sensi dell'articolo L.411-1 del Codice monetario e finanziario francese e del Regolamento generale dell'AMF (autorità francese dei mercati finanziari).
          </p>
          <p class="mb-4"><strong>4.2 Natura dei servizi</strong></p>
          <p class="mb-4">
            Salvo esplicita indicazione contraria, i servizi presentati su questo Sito rientrano nella consulenza in strategia d'impresa e nell'ingegneria finanziaria ("Corporate Finance"). L'uso del termine "Banca d'Affari" sul Sito deve intendersi nella sua accezione economica corrente di "boutique di consulenza in fusioni e acquisizioni" e non può valere come rivendicazione dello status di ente creditizio ai sensi dell'articolo L.511-1 del Codice monetario e finanziario francese. Chaparral Finance non riceve fondi dal pubblico e non concede crediti. Chaparral Finance non esercita l'attività di consulente in investimenti finanziari ai sensi dell'articolo L.541-1 del Codice monetario e finanziario francese.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICOLO 5 - PROPRIETÀ INTELLETTUALE</h3>
          <p class="mb-4">
            L'Editore è proprietario esclusivo di tutti i diritti di proprietà intellettuale, o detiene i diritti d'uso, su tutti gli elementi accessibili sul Sito, sia per quanto riguarda la struttura sia per testi, immagini, grafiche, logo, icone, suoni e software.
          </p>
          <p class="mb-4">
            Qualsiasi riproduzione, rappresentazione, modifica, pubblicazione o adattamento, totale o parziale, degli elementi del Sito, con qualsiasi mezzo o procedimento, è vietata senza la previa autorizzazione scritta dell'Editore, in conformità con gli articoli L.335-2 e seguenti del Codice della proprietà intellettuale francese.
          </p>
          <p class="mb-4">
            I marchi citati (in particolare quelli di clienti o partner nella sezione "Track Record" o "Transazioni") sono di proprietà dei rispettivi titolari. La loro presenza sul Sito non implica alcun rapporto giuridico permanente tra Chaparral Finance e tali soggetti al di là degli incarichi svolti.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICOLO 6 - LEGGE APPLICABILE E FORO COMPETENTE</h3>
          <p class="mb-4">
            Le presenti note legali sono regolate dalla legge francese. In caso di controversia e in assenza di accordo amichevole, la controversia sarà portata davanti ai tribunali competenti del distretto della Corte d'Appello di PARIGI, nonostante la pluralità di convenuti o la chiamata in garanzia.
          </p>
        </section>

        <div class="w-full h-px bg-white/10 my-16"></div>

        <section id="privacy">
          <h2 class="text-2xl font-medium text-white mb-6 serif">ARTICOLO 7 - POLITICA DI PROTEZIONE DEI DATI PERSONALI</h2>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">1. Premessa e Impegno</h3>
          <p class="mb-4">
            Chaparral Finance si impegna affinché la raccolta e il trattamento dei vostri dati, effettuati a partire dal sito chaparral-finance.com, siano conformi al Regolamento Generale sulla Protezione dei Dati (GDPR) e alla legge francese "Informatique et Libertés". Chaparral Finance vigila in particolare sul rispetto dei principi di liceità, correttezza, trasparenza, minimizzazione dei dati, limitazione dei periodi di conservazione e sicurezza dei trattamenti, in conformità con l'articolo 5 del GDPR.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">2. Identità del Titolare del Trattamento</h3>
          <p class="mb-4">
            Il titolare del trattamento è la società CHAPARRAL FINANCE, con sede al 25, rue du Général Foy, 75008 Parigi, rappresentata dal suo Presidente.
          </p>
          <p class="mb-4">
            La società non ha designato un Responsabile della Protezione dei Dati (DPO), non essendovi legalmente tenuta in considerazione della natura dei suoi trattamenti.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">3. Dati Raccolti e Finalità</h3>
          <p class="mb-4">
            Chaparral Finance si assicura che i dati raccolti siano adeguati, pertinenti e limitati a quanto strettamente necessario rispetto alle finalità perseguite.
          </p>

          <div class="space-y-4">
            <div>
              <p class="font-medium text-white/90">Identità e recapiti professionali (cognome, nome, email professionale, numero di telefono)</p>
              <ul class="list-disc pl-5 mt-2 space-y-1 text-white/70 text-sm">
                <li><strong>Finalità:</strong> gestione delle richieste inviate tramite il modulo di contatto, fissazione di appuntamenti e scambi precontrattuali.</li>
                <li><strong>Base giuridica:</strong> esecuzione di misure precontrattuali adottate su richiesta dell'interessato (articolo 6(1)(b) GDPR).</li>
              </ul>
            </div>

            <div>
              <p class="font-medium text-white/90">Dati di navigazione (indirizzo IP, cookie, log tecnici)</p>
              <ul class="list-disc pl-5 mt-2 space-y-1 text-white/70 text-sm">
                <li><strong>Finalità:</strong> misurazione dell'audience, miglioramento del funzionamento del sito e sicurezza dei sistemi informativi.</li>
                <li><strong>Base giuridica:</strong>
                  <ul class="list-circle pl-5 mt-1">
                    <li>il consenso dell'utente per i cookie non strettamente necessari;</li>
                    <li>il legittimo interesse di Chaparral Finance alla sicurezza del sito e alla prevenzione degli abusi (articolo 6(1)(f) GDPR).</li>
                  </ul>
                </li>
              </ul>
            </div>
          </div>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">4. Periodo di Conservazione</h3>
          <p class="mb-4">
            I dati personali relativi ai prospect sono conservati per una durata massima di tre (3) anni a decorrere dall'ultimo contatto attivo proveniente dall'interessato (richiesta di informazioni, presa di contatto, scambio di email o interazione comprovata).
          </p>
          <p class="mb-4">
            I dati tecnici di navigazione sono conservati per una durata non eccedente quella strettamente necessaria alle finalità di sicurezza e di misurazione dell'audience.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">5. Destinatari e Trasferimento dei Dati</h3>
          <p class="mb-4">
            I dati personali raccolti sono destinati esclusivamente ai soci e ai collaboratori autorizzati di Chaparral Finance, nei limiti delle rispettive attribuzioni.
          </p>
          <p class="mb-4">
            I dati possono inoltre essere trattati da fornitori tecnici (in particolare hosting, manutenzione o strumenti informatici), che agiscono in qualità di responsabili del trattamento ai sensi del GDPR e sono soggetti a obblighi contrattuali di riservatezza e sicurezza.
          </p>
          <p class="mb-4">
            I dati sono ospitati all'interno dell'Unione europea. In caso di trasferimento di dati al di fuori dell'Unione europea, tale trasferimento sarebbe disciplinato da garanzie adeguate, in particolare le clausole contrattuali tipo adottate dalla Commissione europea, in conformità con gli articoli 44 e seguenti del GDPR.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">6. I Vostri Diritti in Materia di Protezione dei Dati</h3>
          <p class="mb-4">
            In conformità con la normativa applicabile, disponete dei diritti di accesso, rettifica, cancellazione, limitazione, opposizione e portabilità dei vostri dati personali.
          </p>
          <p class="mb-4">
            Qualora il trattamento sia fondato sul vostro consenso, potete revocarlo in qualsiasi momento, senza pregiudicare la liceità del trattamento basato sul consenso effettuato prima di tale revoca.
          </p>
          <p class="mb-4">
            Qualora il trattamento sia fondato sul legittimo interesse di Chaparral Finance, avete il diritto di opporvi in qualsiasi momento per motivi connessi alla vostra situazione particolare.
          </p>
          <p class="mb-4">
            I dati indicati come obbligatori nei moduli condizionano il trattamento della vostra richiesta; in mancanza, Chaparral Finance potrebbe non essere in grado di rispondervi.
          </p>
          <p class="mb-4">
            La gestione dei cookie è assicurata tramite uno strumento di gestione del consenso accessibile alla prima visita del Sito e in qualsiasi momento successivo. L'Utente può così accettare, rifiutare o configurare l'uso dei cookie in conformità con la normativa applicabile.
          </p>
          <p class="mb-4">
            Per esercitare i vostri diritti, potete contattare Chaparral Finance:
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>Via email:</strong> <a href="mailto:contact@chaparral-finance.fr" class="text-white hover:underline">contact@chaparral-finance.fr</a></li>
            <li><strong>Per posta:</strong> 25, rue du Général Foy, 75008 Parigi</li>
          </ul>
          <p class="mb-4">
            Se, dopo averci contattato, ritenete che i vostri diritti non siano stati rispettati, potete presentare un reclamo all'autorità francese per la protezione dei dati (Commission Nationale de l'Informatique et des Libertés - CNIL).
          </p>
        </section>

      </div>
    </div>
  </main>

  <!-- Footer -->

<Fragment slot="scripts">

  <script is:inline>
    lucide.createIcons();

    // Initial Load Animation
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        document.body.classList.add('loaded');
      });
    } else {
      document.body.classList.add('loaded');
    }

    // Page transition
    function initPageTransition() {
      document.querySelectorAll('a[href]').forEach(link => {
        const href = link.getAttribute('href') || '';
        
        if (link.hostname !== window.location.hostname) return;
        if (link.hasAttribute('target')) return;
        if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
        
        link.addEventListener('click', (e) => {
          e.preventDefault();
          document.body.classList.add('nav-transitioning');
          setTimeout(() => {
            window.location.href = href;
          }, 150);
        });
      });
      
      window.addEventListener('beforeunload', () => {
        document.body.classList.add('nav-transitioning');
      });
      
      window.addEventListener('pageshow', (e) => {
        if (e.persisted) {
          document.body.classList.remove('nav-transitioning');
        }
      });
    }
    
    document.body.classList.remove('nav-transitioning');
    initPageTransition();

    // Mobile Menu
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');

    function openMenu() { menu.classList.remove('translate-x-full'); }
    function closeMenu() { menu.classList.add('translate-x-full'); }

    if (menuBtn) menuBtn.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);

    const mobileLinks = document.querySelectorAll('.mobile-link');
    mobileLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  </script>
</Fragment>

</Base>
