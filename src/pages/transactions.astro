        <div class="skeleton-card" data-skeleton="true"><div class="skeleton-element skeleton-sector"></div><div class="skeleton-avatars"><div class="skeleton-element skeleton-avatar"></div><div class="skeleton-element skeleton-arrow"></div><div class="skeleton-element skeleton-avatar"></div></div><div class="skeleton-names"><div class="skeleton-element skeleton-name"></div><div class="skeleton-element skeleton-name"></div></div><div class="skeleton-element skeleton-title"></div></div>
