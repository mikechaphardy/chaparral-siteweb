</Fragment>

<Fragment slot="styles">
<style is:inline>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #0A1A2A;
    }
    h1, h2, h3, .serif {
      font-family: 'Playfair Display', serif;
    }
    /* Smooth scrolling */
    html { scroll-behavior: smooth; }
    /* Card Hover Effects */
    .transaction-card {
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .transaction-card:hover {
      transform: translateY(-4px);
    }
    /* Safari fix for backface-visibility */
    .card-face {
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      -webkit-transform: translateZ(0);
      transform: translateZ(0);
    }
    .card-back {
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      -webkit-transform: rotateY(180deg) translateZ(1px);
      transform: rotateY(180deg) translateZ(1px);
    }
    /* Flipped state for touch devices */
    .transaction-card.is-flipped .card-inner {
      -webkit-transform: rotateY(180deg);
      transform: rotateY(180deg);
    }
    /* Mobile Menu Transition */
    #mobile-menu {
      transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Skeleton Loading Animation */
    @keyframes shimmer {
      0% {
        background-position: -200% 0;
      }
      100% {
        background-position: 200% 0;
      }
    }
    .skeleton-element {
      background: linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.03) 25%,
        rgba(255, 255, 255, 0.08) 50%,
        rgba(255, 255, 255, 0.03) 75%
      );
      background-size: 200% 100%;
      animation: shimmer 1.5s ease-in-out infinite;
      border-radius: 4px;
    }
    .skeleton-card {
      height: 320px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.05);
      background: linear-gradient(to bottom right, rgba(30, 58, 138, 0.15), rgba(10, 26, 42, 0.8));
      position: relative;
      overflow: hidden;
      padding: 24px;
      display: flex;
      flex-direction: column;
    }
    .skeleton-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        90deg,
        transparent 25%,
        rgba(255, 255, 255, 0.03) 50%,
        transparent 75%
      );
      background-size: 200% 100%;
      animation: shimmer 1.5s ease-in-out infinite;
      pointer-events: none;
    }
    .skeleton-sector {
      width: 80px;
      height: 12px;
      margin-left: auto;
    }
    .skeleton-avatars {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 56px;
      padding: 0 8px;
    }
    .skeleton-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
    }
    .skeleton-arrow {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      opacity: 0.3;
    }
    .skeleton-names {
      display: flex;
      justify-content: space-between;
      margin-top: 12px;
      padding: 0 8px;
    }
    .skeleton-name {
      width: 60px;
      height: 10px;
    }
    .skeleton-title {
      margin-top: auto;
      width: 120px;
      height: 20px;
    }

    /* Navigation transition state - disable backdrop blur during page switch */
    body.nav-transitioning header {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      background-color: #0A1A2A !important;
    }
    /* Page transition overlay */
    #page-transition-overlay {
      position: fixed;
      inset: 0;
      background-color: #0A1A2A;
      z-index: 9999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease-out;
    }
    body.nav-transitioning #page-transition-overlay {
      opacity: 1;
      pointer-events: all;
    }
  </style>
</Fragment>


  <!-- TRANSACTIONS SECTION - GRID LAYOUT (MAIN CONTENT) -->
