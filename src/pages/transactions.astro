              {{description}}
            </p>
          </div>
        </div>
      </div>
    </div>
  </template>

  <script is:inline define:vars={{ transactions }}>
    // Données des transactions
    /**
     * Helper to get font size class based on text length
     */
    function getFontSizeClass(text) {
      if (!text) return 'text-lg';
      if (text.length > 3) return 'text-[10px] leading-tight';
      if (text.length > 2) return 'text-sm';
      return 'text-lg';
    }

    /**
     * Fonction pour remplacer les placeholders dans le template
     */
    function replacePlaceholders(template, data) {
      let html = template.innerHTML;
      
      // Calculate font sizes for initials
      const sellerSizeClass = getFontSizeClass(data.seller_initials);
      const buyerSizeClass = getFontSizeClass(data.buyer_initials);
      
      // Replace content placeholders
      html = html.replace(/\{\{sector\}\}/g, escapeHtml(data.sector));
      html = html.replace(/\{\{seller\}\}/g, escapeHtml(data.seller));
      
      // Handle seller initials with dynamic font size
      // We need to find the span containing seller_initials and replace its class or content
      // Since we're doing simple string replacement, we can replace the class in the template if we modify it first,
      // or we can just replace the variable and assume the template has a standard class we can target?
      // Actually, regex replacement on the HTML string is risky if we try to change classes.
      // Better approach: The template has <span class="... text-lg">{{seller_initials}}</span>
      // We can replace "text-lg" locally within the replacement logic, but that's hard with just string replace.
      
      // Alternative: Inject the class into the data object and use a new placeholder {{seller_size_class}} in template?
      // That requires changing the template.
      
      // Let's modify the template to use a placeholder for the class, OR 
      // do a regex replace on the specific span context.
      
      // Context from file: 
      // <span class="font-serif font-bold text-lg">{{seller_initials}}</span>
      
      // Let's replace the placeholder AND the surrounding class in one go if possible, 
      // or better: let's modify the template to accept a class placeholder? 
      // No, user didn't ask to change template structure.
      
      // Let's use regex to find the specific span with text-lg and the placeholder
      
      // First, let's simple replace the content
      html = html.replace(/\{\{sector\}\}/g, escapeHtml(data.sector));
      html = html.replace(/\{\{seller\}\}/g, escapeHtml(data.seller));
      html = html.replace(/\{\{buyer\}\}/g, escapeHtml(data.buyer));
      html = html.replace(/\{\{deal_type\}\}/g, escapeHtml(data.deal_type));
      html = html.replace(/\{\{description\}\}/g, escapeHtml(data.description));
      html = html.replace(/\{\{image\}\}/g, escapeHtml(data.image));
      html = html.replace(/\{\{alt\}\}/g, escapeHtml(data.alt));
      
      // Now handle initials and their font sizes
      // We'll replace the text-lg class specifically for the spans containing the initials
      // This relies on the exact string structure in the template
      
      // Replace seller initials and adjust font size
      html = html.replace(
        /class="font-serif font-bold text-lg">{{seller_initials}}<\/span>/g, 
        `class="font-serif font-bold ${sellerSizeClass}">${escapeHtml(data.seller_initials)}</span>`
      );
      
      // Replace buyer initials and adjust font size
      html = html.replace(
        /class="font-serif font-bold text-lg">{{buyer_initials}}<\/span>/g, 
        `class="font-serif font-bold ${buyerSizeClass}">${escapeHtml(data.buyer_initials)}</span>`
      );

      // Fallback for standard replacement if regex didn't match (safety)
      html = html.replace(/\{\{seller_initials\}\}/g, escapeHtml(data.seller_initials));
      html = html.replace(/\{\{buyer_initials\}\}/g, escapeHtml(data.buyer_initials));
      
      return html;
    }

    /**
     * Fonction pour échapper les caractères HTML
     */
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    /**
     * Infinite Scroll Implementation
     * Loads 12 cards initially, then 12 more as user scrolls
     */
    const CARDS_PER_BATCH = 12;
    let currentIndex = 0;
    let sortedTransactions = [];
    let isLoading = false;
    let allLoaded = false;

    /**
     * Create skeleton loading cards
     */
    function createSkeletons(count = CARDS_PER_BATCH) {
      const grid = document.getElementById('transactions-grid');
      if (!grid) return;
      
      const skeletons = [];
      for (let i = 0; i < count; i++) {
        const skeleton = document.createElement('div');
        skeleton.className = 'skeleton-card';
        skeleton.setAttribute('data-skeleton', 'true');
        skeleton.innerHTML = `
          <div class="skeleton-element skeleton-sector"></div>
          <div class="skeleton-avatars">
            <div class="skeleton-element skeleton-avatar"></div>
            <div class="skeleton-element skeleton-arrow"></div>
            <div class="skeleton-element skeleton-avatar"></div>
          </div>
          <div class="skeleton-names">
            <div class="skeleton-element skeleton-name"></div>
            <div class="skeleton-element skeleton-name"></div>
          </div>
          <div class="skeleton-element skeleton-title"></div>
        `;
        grid.appendChild(skeleton);
        skeletons.push(skeleton);
      }
      return skeletons;
    }

    /**
     * Remove skeleton loading cards
     */
    function removeSkeletons() {
      const grid = document.getElementById('transactions-grid');
      if (!grid) return;
      
      const skeletons = grid.querySelectorAll('[data-skeleton="true"]');
      skeletons.forEach(skeleton => skeleton.remove());
    }

    /**
     * Load a batch of transaction cards
     */
    function loadMoreCards() {
      if (isLoading || allLoaded) return;
      
      const grid = document.getElementById('transactions-grid');
      const template = document.getElementById('transaction-card-template');
      
      if (!grid || !template) return;
      
      isLoading = true;
      
      // Calculate how many cards to load
      const remainingCards = sortedTransactions.length - currentIndex;
      const cardsToLoad = Math.min(CARDS_PER_BATCH, remainingCards);
      
      // Show skeletons for upcoming cards (only for infinite scroll, not initial load)
      if (currentIndex > 0) {
        createSkeletons(cardsToLoad);
      }
      
      // Simulate minimal delay to show loading state (for smoother UX)
      const loadDelay = currentIndex > 0 ? 100 : 0;
      
      setTimeout(() => {
        // Remove skeletons before adding real cards
        removeSkeletons();
        
        // Get next batch
        const endIndex = Math.min(currentIndex + CARDS_PER_BATCH, sortedTransactions.length);
        const batch = sortedTransactions.slice(currentIndex, endIndex);
        
        // Append cards to grid
        batch.forEach(transaction => {
          const cardHtml = replacePlaceholders(template, transaction);
          const tempDiv = document.createElement('div');
          tempDiv.innerHTML = cardHtml;
          const card = tempDiv.firstElementChild;
          grid.appendChild(card);
        });
        
        currentIndex = endIndex;
        isLoading = false;
        
        // Check if all cards are loaded
        if (currentIndex >= sortedTransactions.length) {
          allLoaded = true;
          // Remove the sentinel if all loaded
          const sentinel = document.getElementById('scroll-sentinel');
          if (sentinel) sentinel.remove();
        }
      }, loadDelay);
    }

    /**
     * Initialize infinite scroll with Intersection Observer
     */
    function initInfiniteScroll() {
      const grid = document.getElementById('transactions-grid');
      if (!grid) return;
      
      // Create sentinel element (invisible element at the bottom)
      const sentinel = document.createElement('div');
      sentinel.id = 'scroll-sentinel';
      sentinel.className = 'h-10 w-full';
      sentinel.setAttribute('aria-hidden', 'true');
      grid.parentElement.appendChild(sentinel);
      
      // Create intersection observer
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !allLoaded) {
            loadMoreCards();
          }
        });
      }, {
        rootMargin: '200px', // Start loading before user reaches the bottom
        threshold: 0
      });
      
      observer.observe(sentinel);
    }

    /**
     * Fonction principale pour rendre les transactions
     */
    function renderTransactions() {
      const grid = document.getElementById('transactions-grid');
      const template = document.getElementById('transaction-card-template');
      
      if (!grid || !template) {
        console.error('Éléments requis non trouvés');
        return;
      }

      // Reset state
      currentIndex = 0;
      allLoaded = false;

      // Sort transactions by order (ascending)
      sortedTransactions = [...transactions].sort((a, b) => a.order - b.order);

      // Remove existing skeleton cards (they were in HTML for initial load)
      removeSkeletons();
      
      // Get initial batch
      const endIndex = Math.min(CARDS_PER_BATCH, sortedTransactions.length);
      const batch = sortedTransactions.slice(0, endIndex);
      
      // Append cards to grid
      batch.forEach(transaction => {
        const cardHtml = replacePlaceholders(template, transaction);
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = cardHtml;
        const card = tempDiv.firstElementChild;
        grid.appendChild(card);
      });
      
      currentIndex = endIndex;
      
      // Check if all cards are loaded
      if (currentIndex >= sortedTransactions.length) {
        allLoaded = true;
      } else {
        // Initialize infinite scroll only if there are more cards
        initInfiniteScroll();
      }
    }

    /**
     * Initialize card flip on tap/click for touch devices
     */
    function initCardFlip() {
      const grid = document.getElementById('transactions-grid');
      if (!grid) return;

      // Use event delegation for dynamically loaded cards
      grid.addEventListener('click', (e) => {
        const card = e.target.closest('.transaction-card');
        if (!card) return;

        // Toggle the flipped state
        card.classList.toggle('is-flipped');
      });

      // Close flipped card when clicking outside
      document.addEventListener('click', (e) => {
        if (!e.target.closest('.transaction-card')) {
          // Unflip all cards when clicking outside
          document.querySelectorAll('.transaction-card.is-flipped').forEach(card => {
            card.classList.remove('is-flipped');
          });
        }
      });
    }

    /**
     * Gestion du menu mobile
     */
    function initMobileMenu() {
      const menuBtn = document.getElementById('mobile-menu-btn');
      const menuClose = document.getElementById('mobile-menu-close');
      const menu = document.getElementById('mobile-menu');

      if (!menuBtn || !menuClose || !menu) return;

      function openMenu() {
        menu.classList.remove('translate-x-full');
      }

      function closeMenu() {
        menu.classList.add('translate-x-full');
      }

      menuBtn.addEventListener('click', openMenu);
      menuClose.addEventListener('click', closeMenu);

      // Fermer le menu lors du clic sur un lien
      const mobileLinks = menu.querySelectorAll('.mobile-link');
      mobileLinks.forEach(link => {
        link.addEventListener('click', closeMenu);
      });
    }

    /**
     * Mise à jour des liens de navigation actifs
     */
    function updateActiveNavLinks() {
      const pathname = window.location.pathname.toLowerCase();
      
      // Helper to extract page name from path (works for both /page and /page.html)
      function getPageName(path) {
        // Remove trailing slash
        const cleanPath = path.replace(/\/$/, '');
        // Get last segment
        const lastSegment = cleanPath.split('/').pop() || '';
        // Remove .html extension
        return lastSegment.replace('.html', '').toLowerCase();
      }
      
      const currentPage = getPageName(pathname);
      
      // Helper to check if current page matches a link
      function isActivePage(href) {
        const linkPage = getPageName(href);
        
        // Handle home/index page
        if (linkPage === 'index' || linkPage === '') {
          return currentPage === 'index' || currentPage === '' || pathname === '/';
        }
        
        // Direct page name comparison
        return currentPage === linkPage;
      }
      
      // Update desktop nav links
      const navLinks = document.querySelectorAll('.nav-link');
      navLinks.forEach(link => {
        const linkPath = link.getAttribute('href');
        if (isActivePage(linkPath)) {
          link.classList.remove('text-[#BFC0AB]');
          link.classList.add('text-white');
        } else {
          link.classList.remove('text-white');
          link.classList.add('text-[#BFC0AB]');
        }
      });
      
      // Update mobile nav links
      const mobileLinks = document.querySelectorAll('.mobile-link');
      mobileLinks.forEach(link => {
        const linkPath = link.getAttribute('href');
        if (isActivePage(linkPath)) {
          link.classList.remove('text-[#D3D3B9]');
          link.classList.add('text-white');
        } else {
          link.classList.remove('text-white');
          link.classList.add('text-[#D3D3B9]');
        }
      });
    }

    /**
     * Page transition - prevent video freeze glitch during navigation
     */
    function initPageTransition() {
      document.querySelectorAll('a[href]').forEach(link => {
        const href = link.getAttribute('href') || '';
        
        // Skip external links, mailto, tel, hash anchors, and links with target
        if (link.hostname !== window.location.hostname) return;
        if (link.hasAttribute('target')) return;
        if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
        
        link.addEventListener('click', (e) => {
          e.preventDefault();
          
          // Disable backdrop blur and show overlay
          document.body.classList.add('nav-transitioning');
          
          // Navigate after brief fade (150ms)
          setTimeout(() => {
            window.location.href = href;
          }, 150);
        });
      });
      
      // Also handle beforeunload to catch browser back/forward
      window.addEventListener('beforeunload', () => {
        document.body.classList.add('nav-transitioning');
      });
    }

    // Initialisation au chargement de la page
    document.addEventListener('DOMContentLoaded', () => {
      initPageTransition();
      renderTransactions();
      initCardFlip();
      initMobileMenu();
      updateActiveNavLinks();
    });
  </script>
</Fragment>

