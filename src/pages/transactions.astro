<Fragment slot="scripts">

  <!-- Template pour les cartes de transaction -->
  <template is:raw id="transaction-card-template">
    <div class="transaction-card group [perspective:1000px] h-80 relative cursor-pointer">
      <div class="card-inner relative w-full h-full transition-all duration-700 [transform-style:preserve-3d] group-hover:[transform:rotateY(180deg)]">
        <!-- Face avant -->
        <div class="card-face overflow-hidden flex flex-col bg-gradient-to-br from-[#1e3a8a]/20 to-[#0A1A2A] w-full h-full border-white/5 border rounded-xl absolute top-0 right-0 bottom-0 left-0 shadow-lg">
