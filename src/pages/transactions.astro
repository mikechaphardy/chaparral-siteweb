        </div>
        <!-- Face arrière -->
        <div class="card-back absolute inset-0 w-full h-full bg-white rounded-xl overflow-hidden shadow-lg border border-white/20 flex flex-col">
          <div class="h-[50%] w-full bg-white relative overflow-hidden flex items-center justify-center p-4">
            <img src="{{image}}" loading="lazy" decoding="async" class="w-full h-full object-contain" alt="{{alt}}">
          </div>
          <div class="p-5 flex flex-col justify-center items-center text-center flex-grow bg-white border-t border-gray-100">
