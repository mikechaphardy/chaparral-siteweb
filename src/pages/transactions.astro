---
import Base from '../layouts/Base.astro';
import transactions from '../data/transactions.json';
---
<Base current="transactions" bodyClass="antialiased flex flex-col min-h-screen overflow-x-hidden text-[#D3D3B9] bg-[#0A1A2A]">

<Fragment slot="head">
<title>Transactions - Chaparral Finance</title>
  <meta name="description" content="Découvrez nos transactions récentes : cessions, LBO, levées de fonds et croissances externes réalisées auprès d'entreprises françaises et européennes.">
  <link rel="canonical" href="https://chaparral-finance.com/transactions">
  

  <!-- Open Graph / Social Media -->
  <meta property="og:title" content="Transactions - Chaparral Finance">
  <meta property="og:description" content="Découvrez nos transactions récentes : cessions, LBO, levées de fonds et croissances externes réalisées auprès d'entreprises françaises et européennes.">
  <meta property="og:url" content="https://chaparral-finance.com/transactions">
  <meta property="og:type" content="website">
