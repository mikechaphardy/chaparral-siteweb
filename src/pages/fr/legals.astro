---
import Base from '../../layouts/Base.astro';
---
<Base current="legals" locale="fr" path="/legals" bodyClass="antialiased flex flex-col min-h-screen overflow-x-hidden bg-[#0A1A2A]">

<Fragment slot="head">
<title>Mentions Légales et la Politique de Protection des Données - Chaparral Finance</title>
  <meta name="description" content="Mentions légales, conditions générales d'utilisation et politique de protection des données du site Chaparral Finance.">
  <link rel="canonical" href="https://www.chaparral-finance.fr/legals">
  

  <!-- Open Graph / Social Media -->
  <meta property="og:title" content="Mentions Légales et la Politique de Protection des Données - Chaparral Finance">
  <meta property="og:description" content="Mentions légales, conditions générales d'utilisation et politique de protection des données du site Chaparral Finance.">
  <meta property="og:url" content="https://www.chaparral-finance.fr/legals">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://res.cloudinary.com/drncmlu30/image/upload/v1766653300/Airbrush-OBJECT-REMOVER-1766652971579_qx1gwx.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Chaparral Finance - Mentions Légales">

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Mentions Légales et la Politique de Protection des Données - Chaparral Finance">
  <meta name="twitter:description" content="Mentions légales, conditions générales d'utilisation et politique de protection des données du site Chaparral Finance.">
  <meta name="twitter:image" content="https://res.cloudinary.com/drncmlu30/image/upload/v1766653300/Airbrush-OBJECT-REMOVER-1766652971579_qx1gwx.png">

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Mentions Légales et la Politique de Protection des Données - Chaparral Finance",
      "url": "https://www.chaparral-finance.fr/legals",
      "isPartOf": {
        "@type": "WebSite",
        "name": "Chaparral Finance",
        "url": "https://www.chaparral-finance.fr/"
      }
    }
  </script>
</Fragment>

<Fragment slot="styles">
<style is:inline>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #0A1A2A;
      color: #D3D3B9;
    }
    h1, h2, h3, h4, .serif {
      font-family: 'Playfair Display', serif;
    }
    /* Smooth scrolling */
    html { scroll-behavior: smooth; }
    
    /* Navigation transition state */
    body.nav-transitioning header {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      background-color: #0A1A2A !important;
    }
    /* Page transition overlay */
    #page-transition-overlay {
      position: fixed;
      inset: 0;
      background-color: #0A1A2A;
      z-index: 9999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease-out;
    }
    body.nav-transitioning #page-transition-overlay {
      opacity: 1;
      pointer-events: all;
    }
    
    /* Page Load Animation */
    body { opacity: 0; transition: opacity 0.6s ease-out; }
    body.loaded { opacity: 1; }

    /* Mobile Menu Transition */
    #mobile-menu {
      transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    }
  </style>
</Fragment>


  <!-- MAIN CONTENT: LEGAL MENTIONS -->
  <main class="flex-grow pt-16 pb-32">
    <div class="md:px-12 max-w-4xl mx-auto px-6">
      
      <!-- Header -->
      <div class="mb-16 border-b border-white/10 pb-12">
        <h1 class="serif md:text-5xl text-3xl font-medium text-white tracking-tight mb-6">Mentions Légales et la Politique de Protection des Données</h1>
        <p class="text-lg font-light text-[#D3D3B9]/80">
          Mentions légales, conditions générales d'utilisation et politique de protection des données.
        </p>
      </div>

      <!-- Legal Content -->
      <div class="space-y-12 text-[#D3D3B9]/90 font-light leading-relaxed">
        
        <section>
          <h2 class="text-2xl font-medium text-white mb-6 serif">MENTIONS LÉGALES ET POLITIQUE DE PROTECTION DES DONNEES</h2>
          <p class="mb-4 font-medium text-white/80">En vigueur au 5 janvier 2026</p>
          <p class="mb-4">
            Conformément aux dispositions des Articles 6-III et 19 de la Loi n°2004-575 du 21 juin 2004 pour la Confiance dans l'Économie Numérique (dite L.C.E.N.), il est porté à la connaissance des utilisateurs et visiteurs, ci-après l'"Utilisateur", du site https://www.chaparral-finance.fr/, ci-après le "Site", les présentes mentions légales.
          </p>
          <p class="mb-4">
            La connexion et la navigation sur le Site par l’Utilisateur implique l'acceptation intégrale et sans réserve des présentes mentions légales. Ces dernières sont accessibles sur le Site à la rubrique « Mentions légales ».
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 1 - L'ÉDITEUR</h3>
          <p class="mb-4">
            L’édition et la direction de la publication du Site sont assurées par la société CHAPARRAL FINANCE SAS agissant sous le nom commercial Chaparral Finance.
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>Forme Juridique :</strong> Société par Actions Simplifiée</li>
            <li><strong>Capital Social :</strong> 100.000,00 Euros</li>
            <li><strong>RCS Paris :</strong> XXX XXX XXX</li>
            <li><strong>Siège Social :</strong> 25 rue du Général Foy, 75008 Paris, France</li>
            <li><strong>Adresse E-mail :</strong> contact@chaparral-finance.fr</li>
            <li><strong>Directeur de la Publication :</strong> Monsieur Maxime Dugast, Président</li>
          </ul>
          <p class="mb-4">
            La société n’exerce pas une activité réglementée soumise à agrément / immatriculation spécifique (AMF/ACPR)
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 2 - L'HÉBERGEUR</h3>
          <p class="mb-4">L'hébergement du Site est assuré par la société :</p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>Raison Sociale :</strong> Vercel Inc.</li>
            <li><strong>Adresse :</strong> 650 California St, San Francisco, CA 94108, États-Unis</li>
            <li><strong>Site Web :</strong> https://vercel.com</li>
            <li><strong>Note Technique :</strong> Conception et Développement DEVINOTEK SAS</li>
          </ul>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 3 - ACCÈS AU SITE ET RESPONSABILITÉ</h3>
          <p class="mb-4">
            Le Site est accessible par tout endroit, 7j/7, 24h/24 sauf cas de force majeure, interruption programmée ou non et pouvant découlant d’une nécessité de maintenance. En cas de modification, interruption ou suspension des services du Site, l'Éditeur ne saurait être tenu responsable.
          </p>
          <p class="mb-4">
            <strong>Limitation de responsabilité sur les informations financières :</strong> Les informations fournies sur le Site le sont à titre informatif. Elles ne sauraient dispenser l'Utilisateur d'une analyse complémentaire et personnalisée. Chaparral Finance ne saurait garantir l'exactitude, la complétude, l'actualité des informations diffusées sur le Site. En conséquence, l'Utilisateur reconnaît utiliser ces informations sous sa responsabilité exclusive. Chaparral Finance ne pourra être tenue responsable des dommages directs ou indirects, tels que pertes financières, pertes de profits, ou pertes d'opportunités, résultant de l'utilisation du Site ou de l'impossibilité d'y accéder.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 4 - AVERTISSEMENT RÉGLEMENTAIRE (MIFID II / AMF)</h3>
          <p class="mb-4"><strong>4.1 Absence d'offre au public</strong></p>
          <p class="mb-4">
            Le contenu de ce Site ne constitue en aucun cas une offre au public de titres financiers, une sollicitation, un démarchage bancaire ou financier, ni une recommandation d'achat ou de vente d'instruments financiers au sens de l'article L.411-1 du Code Monétaire et Financier et du Règlement Général de l'AMF.
          </p>
          <p class="mb-4"><strong>4.2 Nature des prestations</strong></p>
          <p class="mb-4">
            Sauf mention contraire explicite, les prestations présentées sur ce Site relèvent du conseil en stratégie d'entreprise et de l'ingénierie financière ("Corporate Finance"). L'utilisation du terme "Banque d'Affaires" sur le Site doit s'entendre dans son acception économique usuelle de "boutique de conseil en fusions-acquisitions" et ne saurait valoir revendication du statut d'établissement de crédit au sens de l'article L.511-1 du Code Monétaire et Financier. Chaparral Finance ne reçoit pas de fonds du public et n'octroie pas de crédits. Chaparral Finance n’exerce pas l’activité de conseiller en investissements financiers au sens de l’article L.541-1 du Code monétaire et financier.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 5 - PROPRIÉTÉ INTELLECTUELLE</h3>
          <p class="mb-4">
            L'Éditeur est propriétaire exclusif de tous les droits de propriété intellectuelle ou détient les droits d'usage sur tous les éléments accessibles sur le Site, tant sur la structure que sur les textes, images, graphismes, logo, icônes, sons, logiciels.
          </p>
          <p class="mb-4">
            Toute reproduction, représentation, modification, publication, adaptation de tout ou partie des éléments du Site, quel que soit le moyen ou le procédé utilisé, est interdite, sauf autorisation écrite préalable de l'Éditeur, conformément aux articles L.335-2 et suivants du Code de la Propriété Intellectuelle.
          </p>
          <p class="mb-4">
            Les marques citées (notamment celles des clients ou partenaires dans la section "Track Record" ou "Transactions") sont la propriété de leurs détenteurs respectifs. Leur affichage sur le Site ne préjuge pas d'un lien juridique permanent entre Chaparral Finance et ces entités au-delà des missions réalisées.
          </p>
        </section>

        <section>
          <h3 class="text-xl font-medium text-white mb-4">ARTICLE 6 - LOI APPLICABLE ET JURIDICTION</h3>
          <p class="mb-4">
            Les présentes Mentions Légales sont régies par la loi française. En cas de différend et à défaut d'accord amiable, le litige sera porté devant les tribunaux compétents du ressort de la Cour d'Appel de PARIS, nonobstant pluralité de défendeurs ou appel en garantie.
          </p>
        </section>

        <div class="w-full h-px bg-white/10 my-16"></div>

        <section id="privacy">
          <h2 class="text-2xl font-medium text-white mb-6 serif">ARTICLE 7 - POLITIQUE DE PROTECTION DES DONNÉES PERSONNELLES</h2>
          
          <h3 class="text-xl font-medium text-white mt-8 mb-4">1. Préambule et Engagement</h3>
          <p class="mb-4">
            Chaparral Finance s'engage à ce que la collecte et le traitement de vos données, effectués à partir du site chaparral-finance.fr, soient conformes au Règlement Général sur la Protection des Données (RGPD) et à la loi Informatique et Libertés. Chaparral Finance veille notamment au respect des principes de licéité, loyauté, transparence, minimisation des données, limitation des durées de conservation et sécurité des traitements, conformément à l’article 5 du RGPD.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">2. Identité du Responsable de Traitement</h3>
          <p class="mb-4">
            Le responsable du traitement est la société CHAPARRAL FINANCE, sise au 25, rue du Général Foy, 75008 Paris, représentée par son Président.
          </p>
          <p class="mb-4">
            La société n’a pas désigné de Délégué à la Protection des Données (DPO), n’y étant pas légalement tenue au regard de la nature de ses traitements.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">3. Données Collectées et Finalités</h3>
          <p class="mb-4">
            Chaparral Finance s’assure que les données collectées sont adéquates, pertinentes et limitées à ce qui est strictement nécessaire au regard des finalités poursuivies.
          </p>
          
          <div class="space-y-4">
            <div>
              <p class="font-medium text-white/90">Identité et coordonnées professionnelles (nom, prénom, email professionnel, numéro de téléphone)</p>
              <ul class="list-disc pl-5 mt-2 space-y-1 text-white/70 text-sm">
                <li><strong>Finalité :</strong> traitement des demandes formulées via le formulaire de contact, prise de rendez-vous et échanges précontractuels.</li>
                <li><strong>Base légale :</strong> exécution de mesures précontractuelles prises à la demande de la personne concernée (article 6(1)(b) RGPD).</li>
              </ul>
            </div>
            
            <div>
              <p class="font-medium text-white/90">Données de navigation (adresse IP, cookies, journaux techniques)</p>
              <ul class="list-disc pl-5 mt-2 space-y-1 text-white/70 text-sm">
                <li><strong>Finalité :</strong> mesure d’audience, amélioration du fonctionnement du site et sécurité des systèmes d’information.</li>
                <li><strong>Base légale :</strong>
                  <ul class="list-circle pl-5 mt-1">
                    <li>consentement de l’utilisateur pour les cookies non strictement nécessaires ;</li>
                    <li>intérêt légitime de Chaparral Finance pour la sécurité du site et la prévention des abus (article 6(1)(f) RGPD).</li>
                  </ul>
                </li>
              </ul>
            </div>
          </div>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">4. Durée de Conservation</h3>
          <p class="mb-4">
            Les données personnelles relatives aux prospects sont conservées pendant une durée maximale de trois (3) ans à compter du dernier contact actif émanant de la personne concernée (demande d’information, prise de contact, échange d’emails ou interaction avérée).
          </p>
          <p class="mb-4">
            Les données techniques de navigation sont conservées pour une durée n’excédant pas celle strictement nécessaire aux finalités de sécurité et de mesure d’audience.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">5. Destinataires et Transfert de Données</h3>
          <p class="mb-4">
            Les données personnelles collectées sont destinées exclusivement aux associés et collaborateurs habilités de Chaparral Finance, dans la limite de leurs attributions respectives.
          </p>
          <p class="mb-4">
            Les données peuvent également être traitées par des prestataires techniques (notamment hébergement, maintenance ou outils informatiques), agissant en qualité de sous-traitants au sens du RGPD, et soumis à des obligations contractuelles de confidentialité et de sécurité.
          </p>
          <p class="mb-4">
            Les données sont hébergées au sein de l’Union européenne. En cas de transfert de données hors de l’Union européenne, celui-ci serait encadré par des garanties appropriées, notamment les clauses contractuelles types adoptées par la Commission européenne, conformément aux articles 44 et suivants du RGPD.
          </p>

          <h3 class="text-xl font-medium text-white mt-8 mb-4">6. Vos Droits Informatique et Libertés</h3>
          <p class="mb-4">
            Conformément à la réglementation applicable, vous disposez des droits d’accès, de rectification, d’effacement, de limitation, d’opposition et de portabilité de vos données personnelles.
          </p>
          <p class="mb-4">
            Lorsque le traitement est fondé sur votre consentement, vous pouvez le retirer à tout moment, sans porter atteinte à la licéité du traitement fondé sur le consentement effectué avant ce retrait.
          </p>
          <p class="mb-4">
            Lorsque le traitement est fondé sur l’intérêt légitime de Chaparral Finance, vous disposez du droit de vous y opposer à tout moment pour des raisons tenant à votre situation particulière.
          </p>
          <p class="mb-4">
            Les données signalées comme obligatoires dans les formulaires conditionnent le traitement de votre demande ; à défaut de les renseigner, Chaparral Finance pourrait ne pas être en mesure d’y répondre.
          </p>
          <p class="mb-4">
            La gestion des cookies est assurée via un outil de gestion du consentement accessible lors de la première visite sur le Site et à tout moment depuis celui-ci. L’Utilisateur peut ainsi accepter, refuser ou paramétrer l’utilisation des cookies conformément à la réglementation applicable.
          </p>
          <p class="mb-4">
            Pour exercer vos droits, vous pouvez contacter Chaparral Finance :
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>Par email :</strong> <a href="mailto:contact@chaparral-finance.fr" class="text-white hover:underline">contact@chaparral-finance.fr</a></li>
            <li><strong>Par courrier :</strong> 25, rue du Général Foy, 75008 Paris</li>
          </ul>
          <p class="mb-4">
            Si vous estimez, après nous avoir contactés, que vos droits ne sont pas respectés, vous pouvez introduire une réclamation auprès de la Commission Nationale de l’Informatique et des Libertés (CNIL).
          </p>
        </section>
        
      </div>
    </div>
  </main>

  <!-- Footer -->

<Fragment slot="scripts">

  <script is:inline>
    lucide.createIcons();

    // Initial Load Animation
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        document.body.classList.add('loaded');
      });
    } else {
      document.body.classList.add('loaded');
    }

    // Page transition
    function initPageTransition() {
      document.querySelectorAll('a[href]').forEach(link => {
        const href = link.getAttribute('href') || '';
        
        if (link.hostname !== window.location.hostname) return;
        if (link.hasAttribute('target')) return;
        if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
        
        link.addEventListener('click', (e) => {
          e.preventDefault();
          document.body.classList.add('nav-transitioning');
          setTimeout(() => {
            window.location.href = href;
          }, 150);
        });
      });
      
      window.addEventListener('beforeunload', () => {
        document.body.classList.add('nav-transitioning');
      });
      
      window.addEventListener('pageshow', (e) => {
        if (e.persisted) {
          document.body.classList.remove('nav-transitioning');
        }
      });
    }
    
    document.body.classList.remove('nav-transitioning');
    initPageTransition();

    // Mobile Menu
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');

    function openMenu() { menu.classList.remove('translate-x-full'); }
    function closeMenu() { menu.classList.add('translate-x-full'); }

    if (menuBtn) menuBtn.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);

    const mobileLinks = document.querySelectorAll('.mobile-link');
    mobileLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  </script>
</Fragment>

</Base>
