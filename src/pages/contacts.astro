---
import Base from '../layouts/Base.astro';
---
<Base current="contacts" bodyClass="antialiased flex flex-col min-h-screen overflow-x-hidden text-[#D3D3B9] bg-[#0A1A2A]">

<Fragment slot="head">
<title>Contact - Chaparral Finance</title>
<meta name="description" content="Contactez Chaparral Finance pour discuter de vos projets de M&A, levée de fonds, LBO ou cession. Notre équipe vous accompagne.">
<link rel="canonical" href="https://chaparral-finance.com/contacts">

<!-- Open Graph / Social Media -->
<meta property="og:title" content="Contact - Chaparral Finance">
<meta property="og:description" content="Contactez Chaparral Finance pour discuter de vos projets de M&A, levée de fonds, LBO ou cession. Notre équipe d'experts vous accompagne.">
<meta property="og:url" content="https://chaparral-finance.com/contacts">
<meta property="og:type" content="website">
<meta property="og:image" content="https://res.cloudinary.com/drncmlu30/image/upload/v1766653300/Airbrush-OBJECT-REMOVER-1766652971579_qx1gwx.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Chaparral Finance - Nous contacter">

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Contact - Chaparral Finance">
<meta name="twitter:description" content="Contactez Chaparral Finance pour discuter de vos projets de M&A, levée de fonds, LBO ou cession. Notre équipe vous accompagne.">
<meta name="twitter:image" content="https://res.cloudinary.com/drncmlu30/image/upload/v1766653300/Airbrush-OBJECT-REMOVER-1766652971579_qx1gwx.png">

<!-- Schema.org (JSON-LD) -->
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"ContactPage","name":"Contact - Chaparral Finance","url":"https://chaparral-finance.com/contacts","isPartOf":{"@type":"WebSite","name":"Chaparral Finance","url":"https://chaparral-finance.com/"}}
</script>
</Fragment>

<Fragment slot="styles">
<style is:inline>
body {
font-family: 'Inter', sans-serif;
background-color: #0A1A2A;
}
h1,
h2,
h3,
.serif {
font-family: 'Playfair Display', serif;
}
html {
scroll-behavior: smooth;
}
/* Navigation transition state - disable backdrop blur during page switch */
body.nav-transitioning header {
backdrop-filter: none !important;
-webkit-backdrop-filter: none !important;
background-color: #0A1A2A !important;
}
/* Page transition overlay */
#page-transition-overlay {
position: fixed;
inset: 0;
background-color: #0A1A2A;
z-index: 9999;
opacity: 0;
pointer-events: none;
transition: opacity 0.15s ease-out;
}
body.nav-transitioning #page-transition-overlay {
opacity: 1;
pointer-events: all;
}
</style>
</Fragment>


  <!-- CONTACT SECTION -->
  <main class="flex-grow bg-[#0A1A2A] pt-36 pb-32 relative">
    <div class="absolute inset-x-0 top-0 h-[850px] overflow-hidden pointer-events-none z-0">
      <video 
        id="contact-video"
        autoplay
        muted 
        playsinline
        preload="auto"
        poster="https://res.cloudinary.com/dddfggfp3/image/upload/v1767488206/contact_posterimage_snhwqj.png"
        class="w-full h-full object-cover opacity-60"
      >
        <source src="https://res.cloudinary.com/dddfggfp3/video/upload/v1767760961/kling_20260107_Image_to_Video_Very_slow__3131_0_1_lqbulg.mp4" type="video/mp4">
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-[#0A1A2A]/20 via-[#0A1A2A]/60 to-[#0A1A2A]"></div>
    </div>
    <!-- Background subtle glow -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#D3D3B9]/5 blur-[120px] rounded-full pointer-events-none -z-0">
    </div>

    <div class="md:px-12 max-w-7xl z-10 mr-auto ml-auto pr-6 pl-6 relative">
      <!-- Header Text -->
      <div class="mb-16">
        
        <h1 class="serif md:text-5xl lg:text-6xl text-4xl font-medium text-white tracking-tight mb-6">Nos bureaux en France</h1>
        <p class="leading-relaxed text-lg font-light text-[#D3D3B9]/60 max-w-2xl">Rien de remplacera jamais un rendez-vous. Contactez-nos équipes pour discuter de votre projet, ou de vos réflexions stratégiques en cours.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <!-- Left Column: Form -->
        <div class="lg:col-span-7">
          <div class="bg-white/5 border border-white/5 rounded-2xl p-8 md:p-10 backdrop-blur-sm">
            <h2 class="text-2xl font-medium text-white tracking-tight mb-8">Nous contacter</h2>

            <form id="contact-form" class="space-y-6">
              <!-- Honeypot field for spam protection -->
              <input type="text" name="_honey" style="display:none">
              <!-- Disable captcha -->
              <input type="hidden" name="_captcha" value="false">
              <!-- Custom subject line -->
              <input type="hidden" name="_subject" value="Nouveau message - Chaparral Finance">
              
              <div class="">
                <label for="name" class="block text-xs font-medium text-[#D3D3B9]/80 mb-2 uppercase tracking-wide">
                    Nom complet
                  </label>
                <input type="text" id="name" name="name" required placeholder="Votre nom complet" class="w-full bg-[#0A1A2A]/50 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-[#D3D3B9]/20 focus:outline-none focus:border-[#D3D3B9]/50 focus:ring-1 focus:ring-[#D3D3B9]/50 transition-all text-sm font-light">
              </div>

              <div class="">
                <label for="email" class="block text-xs font-medium text-[#D3D3B9]/80 mb-2 uppercase tracking-wide">
                    Adresse email
                  </label>
                <input type="email" id="email" name="email" required placeholder="nom@entreprise.com" class="w-full bg-[#0A1A2A]/50 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-[#D3D3B9]/20 focus:outline-none focus:border-[#D3D3B9]/50 focus:ring-1 focus:ring-[#D3D3B9]/50 transition-all text-sm font-light">
              </div>

              <div class="">
                <label for="company" class="block text-xs font-medium text-[#D3D3B9]/80 mb-2 uppercase tracking-wide">
                    Société
                  </label>
                <input type="text" id="company" name="company" placeholder="Nom de votre société" class="w-full bg-[#0A1A2A]/50 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-[#D3D3B9]/20 focus:outline-none focus:border-[#D3D3B9]/50 focus:ring-1 focus:ring-[#D3D3B9]/50 transition-all text-sm font-light">
              </div>

              <div class="">
                <label for="subject" class="block text-xs font-medium text-[#D3D3B9]/80 mb-2 uppercase tracking-wide">
                    Sujet
                  </label>
                <input type="text" id="subject" name="subject" required placeholder="De quoi s'agit-il ?" class="w-full bg-[#0A1A2A]/50 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-[#D3D3B9]/20 focus:outline-none focus:border-[#D3D3B9]/50 focus:ring-1 focus:ring-[#D3D3B9]/50 transition-all text-sm font-light">
              </div>

              <div class="">
                <label for="message" class="block text-xs font-medium text-[#D3D3B9]/80 mb-2 uppercase tracking-wide">
                    Message
                  </label>
                <textarea id="message" name="message" required rows="4" placeholder="Dites-nous comment nous pouvons vous aider..." class="w-full bg-[#0A1A2A]/50 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-[#D3D3B9]/20 focus:outline-none focus:border-[#D3D3B9]/50 focus:ring-1 focus:ring-[#D3D3B9]/50 transition-all text-sm font-light resize-none"></textarea>
              </div>

              <button type="submit" class="w-full bg-[#D3D3B9] hover:bg-white text-[#0A1A2A] font-medium py-3.5 px-6 rounded-lg transition-colors duration-300 mt-2 text-sm tracking-wide">
                  Envoyer le message
                </button>
            </form>
          </div>
          <div class="bg-white/5 border border-white/5 rounded-2xl p-8 md:p-10 backdrop-blur-sm mt-10">
            <h2 class="text-2xl text-white font-medium mb-6 tracking-tight">
              Nous rejoindre
            </h2>
            <p class="text-[#D3D3B9]/80 font-light leading-relaxed">
              Les candidatures pour les offres en ligne peuvent être
              transmises à l’adresse
              <a href="mailto:recrutement@chaparral-finance.fr" class="text-white hover:text-[#D3D3B9] transition-colors">
                recrutement@chaparral-finance.fr
              </a>
              ou déposées directement sur
              <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-white hover:text-[#D3D3B9] transition-colors">
                LinkedIn
              </a>
              .
            </p>
          </div>
        </div>

        <!-- Right Column: Info & Map -->
        <div class="lg:col-span-5 flex flex-col gap-10">
          <!-- Contact Info -->
          <div class="">
            <div class="space-y-5">
              <a href="#" class="flex items-center gap-4 group">
                <div class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[#D3D3B9] group-hover:bg-[#D3D3B9] group-hover:text-[#0A1A2A] transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="mail" class="lucide lucide-mail w-4 h-4"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg>
                </div>
                <span class="group-hover:text-white transition-colors text-sm text-[#D3D3B9]/80">contact@chaparral-finance.fr</span>
              </a>
            </div>
          </div>

          <!-- Map Card -->
          <div class="relative w-full h-[400px] rounded-2xl overflow-hidden border border-white/10 group bg-[#0A1A2A]">
            <!-- Dark Map Image Placeholder -->
            <img src="https://ik.imagekit.io/iokktghdw/SCR-20251221-kvnq.png?w=800&amp;q=80" alt="Map Location" loading="lazy" decoding="async" class="transition-all duration-700 group-hover:opacity-100 group-hover:grayscale-0 group-hover:scale-105 opacity-60 w-full h-full object-cover grayscale" style="background-color: #1a2736">

            <!-- Floating Address Card -->
            <div class="absolute bottom-4 left-4 right-4 bg-[#0A1A2A]/90 backdrop-blur-md border border-white/10 p-5 rounded-xl shadow-2xl">
              <h4 class="font-medium text-white mb-1">Nos bureaux</h4>
              <div class="flex items-start gap-2 mt-3 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="map-pin" class="lucide lucide-map-pin w-4 h-4 text-[#D3D3B9] shrink-0 mt-0.5"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <p class="leading-relaxed text-xs text-[#D3D3B9]/60">
                  16 avenue de Messine, 75008 Paris, France
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer Minimal -->

<Fragment slot="scripts">

  <!-- Success Modal -->
  <div id="success-modal" class="fixed inset-0 z-[100] hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-[#0A1A2A]/90 backdrop-blur-sm transition-opacity duration-300 opacity-0" id="modal-backdrop"></div>
    
    <!-- Modal Content -->
    <div class="relative min-h-screen flex items-center justify-center p-4">
      <div class="bg-[#0A1A2A] border border-white/10 rounded-2xl p-8 md:p-12 max-w-lg w-full shadow-2xl transform scale-95 opacity-0 transition-all duration-300" id="modal-content">
        <div class="flex flex-col items-center text-center">
          <!-- Icon -->
          <div class="w-16 h-16 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[#D3D3B9] mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check">
              <path d="M20 6 9 17l-5-5"></path>
            </svg>
          </div>
          
          <h3 class="font-serif text-3xl text-white mb-4">Message envoyé</h3>
          <p class="text-[#D3D3B9]/80 leading-relaxed mb-8 font-light">
            Merci de nous avoir contactés. Votre message a bien été reçu et notre équipe reviendra vers vous dans les plus brefs délais.
          </p>
          
          <button id="close-modal-btn" class="w-full bg-[#D3D3B9] hover:bg-white text-[#0A1A2A] font-medium py-3.5 px-6 rounded-lg transition-colors duration-300 text-sm tracking-wide">
            Retour au site
          </button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    lucide.createIcons();
    
    // Form Handling with Custom Success Modal
    const contactForm = document.getElementById('contact-form');
    const successModal = document.getElementById('success-modal');
    const modalBackdrop = document.getElementById('modal-backdrop');
    const modalContent = document.getElementById('modal-content');
    const closeModalBtn = document.getElementById('close-modal-btn');
    
    function showModal() {
      if (!successModal) return;
      
      successModal.classList.remove('hidden');
      // Trigger animations
      requestAnimationFrame(() => {
        modalBackdrop.classList.remove('opacity-0');
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
      });
      document.body.style.overflow = 'hidden';
    }
    
    function hideModal() {
      if (!successModal) return;
      
      modalBackdrop.classList.add('opacity-0');
      modalContent.classList.remove('scale-100', 'opacity-100');
      modalContent.classList.add('scale-95', 'opacity-0');
      
      setTimeout(() => {
        successModal.classList.add('hidden');
        document.body.style.overflow = '';
      }, 300);
    }
    
    if (closeModalBtn) {
      closeModalBtn.addEventListener('click', hideModal);
    }
    
    // Close on backdrop click
    if (successModal) {
      successModal.addEventListener('click', (e) => {
        if (e.target === successModal || e.target.closest('#modal-backdrop')) {
          hideModal();
        }
      });
    }

    if (contactForm) {
      contactForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const submitBtn = contactForm.querySelector('button[type="submit"]');
        const originalBtnText = submitBtn.innerText;
        
        // Show loading state
        submitBtn.disabled = true;
        submitBtn.innerText = 'Envoi en cours...';
        
        try {
          const formData = new FormData(contactForm);
          
          const response = await fetch('https://formsubmit.co/ajax/contact@chaparral-finance.fr', {
            method: 'POST',
            headers: { 
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify(Object.fromEntries(formData))
          });
          
          const result = await response.json();
          
          if (result.success) {
            // Success
            contactForm.reset();
            showModal();
          } else {
            throw new Error('Form submission failed');
          }
        } catch (error) {
          console.error('Submission error:', error);
          alert('Une erreur est survenue lors de l\'envoi du message. Veuillez réessayer.');
        } finally {
          // Reset button
          submitBtn.disabled = false;
          submitBtn.innerText = originalBtnText;
        }
      });
    }

      // Page transition - prevent video freeze glitch during navigation
      (function initPageTransition() {
        document.querySelectorAll('a[href]').forEach(link => {
          const href = link.getAttribute('href') || '';
          
          // Skip external links, mailto, tel, hash anchors, and links with target
          if (link.hostname !== window.location.hostname) return;
          if (link.hasAttribute('target')) return;
          if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
          
          link.addEventListener('click', (e) => {
            e.preventDefault();
            
            // Disable backdrop blur and show overlay
            document.body.classList.add('nav-transitioning');
            
            // Navigate after brief fade (150ms)
            setTimeout(() => {
              window.location.href = href;
            }, 150);
          });
        });
        
        // Also handle beforeunload to catch browser back/forward
        window.addEventListener('beforeunload', () => {
          document.body.classList.add('nav-transitioning');
        });
      })();

      // Mobile Menu Logic
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenuClose = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');
      const body = document.body;

      function toggleMenu() {
        const isClosed = mobileMenu.classList.contains('translate-x-full');
        if (isClosed) {
          mobileMenu.classList.remove('translate-x-full');
          body.classList.add('overflow-hidden');
        } else {
          mobileMenu.classList.add('translate-x-full');
          body.classList.remove('overflow-hidden');
        }
      }

      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', toggleMenu);
      }

      if (mobileMenuClose && mobileMenu) {
        mobileMenuClose.addEventListener('click', toggleMenu);
      }

      // Close menu when clicking links
      const mobileLinks = document.querySelectorAll('.mobile-link');
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('translate-x-full');
          body.classList.remove('overflow-hidden');
        });
      });

    /**
     * Contact Video - Safari-compatible initialization
     * Ensures video plays correctly even with poster image
     */
    function initContactVideo() {
      const video = document.getElementById('contact-video');
      if (!video) return;
      
      let hasStarted = false;
      let hasStopped = false;
      
      // Set slower playback rate (0.5 = 50% speed / half speed)
      video.playbackRate = 0.5;
      
      // Stop smoothly BEFORE reaching the end (avoids the jump from 'ended' event)
      video.addEventListener('timeupdate', () => {
        if (hasStopped) return;
        
        // Pause 0.05 seconds before the end to avoid any jump
        if (video.duration && video.currentTime >= video.duration - 0.05) {
          hasStopped = true;
          video.pause();
        }
      });
      
      // Attempt to play the video
      function tryPlay() {
        if (hasStarted) return;
        hasStarted = true;
        
        // Ensure playback rate is set before playing
        video.playbackRate = 0.5;
        
        video.play().catch(() => {
          // Autoplay failed (browser policy) - poster image remains visible
          console.log('Video autoplay blocked by browser');
          hasStarted = false; // Allow retry on user interaction
        });
      }
      
      // Multiple event listeners for Safari compatibility
      // Safari may not fire 'canplaythrough' reliably with poster images
      video.addEventListener('canplaythrough', tryPlay, { once: true });
      video.addEventListener('canplay', tryPlay, { once: true });
      video.addEventListener('loadeddata', tryPlay, { once: true });
      
      // Force load the video (Safari sometimes needs this with poster)
      video.load();
    }

    // Initialize video on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initContactVideo);
    } else {
      initContactVideo();
    }
  </script>



</Fragment>

</Base>
