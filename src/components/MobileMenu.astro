---
// Menu mobile plein écran. Le lien de la page courante est en blanc.
// Sélecteur de langue identique à celui du header (liens croisés domaines).
const { current, locale = 'fr', path = '/' } = Astro.props;

const active = 'mobile-link text-3xl font-serif text-white hover:text-white transition-colors';
const inactive = 'mobile-link text-3xl font-serif text-[#D3D3B9] hover:text-white transition-colors';
const link = (page) => (current === page ? active : inactive);

// Liens internes préfixés par la langue pour ne pas la perdre en naviguant
const base = { fr: '/fr', en: '', it: '/it' }[locale];
const home = base || '/';

const frUrl = path === '/' ? '/fr' : `/fr${path}`;
const enUrl = `${path}?lang=en`;
const itUrl = path === '/' ? '/it' : `/it${path}`;
---
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-[#0A1A2A] transform translate-x-full transition-transform duration-500 ease-in-out lg:hidden flex flex-col">
  <div class="flex items-center justify-between p-6 border-b border-[#D3D3B9]/10">
    <div class="text-[#D3D3B9] font-serif text-xl font-medium">Menu</div>
    <button id="mobile-menu-close" class="text-[#D3D3B9] hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>
  <nav class="flex flex-col p-8 gap-6 items-center justify-center flex-1">
    <a href={home} class={link('home')}>
      Chaparral
    </a>
    <a href={base + '/transactions'} class={link('transactions')}>
      Transactions
    </a>
    <a href={base + '/contacts'} class={link('contacts')}>
      Contact
    </a>
    <div class="flex items-center gap-3 mt-8" aria-label="Langue / Language">
      {locale === 'fr'
        ? <span class="text-white text-sm font-semibold uppercase tracking-widest">FR</span>
        : <a href={frUrl} class="text-[#D3D3B9] hover:text-white transition-colors text-sm font-semibold uppercase tracking-widest" hreflang="fr" lang="fr">FR</a>}
      <span class="text-[#D3D3B9]/40 text-sm">/</span>
      {locale === 'en'
        ? <span class="text-white text-sm font-semibold uppercase tracking-widest">EN</span>
        : <a href={enUrl} class="text-[#D3D3B9] hover:text-white transition-colors text-sm font-semibold uppercase tracking-widest" hreflang="en" lang="en">EN</a>}
      <span class="text-[#D3D3B9]/40 text-sm">/</span>
      {locale === 'it'
        ? <span class="text-white text-sm font-semibold uppercase tracking-widest">IT</span>
        : <a href={itUrl} class="text-[#D3D3B9] hover:text-white transition-colors text-sm font-semibold uppercase tracking-widest" hreflang="it" lang="it">IT</a>}
    </div>
  </nav>
</div>
