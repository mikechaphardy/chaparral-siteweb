---
// Menu mobile plein écran. Le lien de la page courante est en blanc.
const { current } = Astro.props;

const active = 'mobile-link text-3xl font-serif text-white hover:text-white transition-colors';
const inactive = 'mobile-link text-3xl font-serif text-[#D3D3B9] hover:text-white transition-colors';
const link = (page) => (current === page ? active : inactive);
---
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-[#0A1A2A] transform translate-x-full transition-transform duration-500 ease-in-out lg:hidden flex flex-col">
  <div class="flex items-center justify-between p-6 border-b border-[#D3D3B9]/10">
    <div class="text-[#D3D3B9] font-serif text-xl font-medium">Menu</div>
    <button id="mobile-menu-close" class="text-[#D3D3B9] hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>
  <nav class="flex flex-col p-8 gap-6 items-center justify-center flex-1">
    <a href="/" class={link('home')}>
      Chaparral
    </a>
    <a href="/transactions" class={link('transactions')}>
      Transactions
    </a>
    <a href="/contacts" class={link('contacts')}>
      Contact
    </a>
  </nav>
</div>
