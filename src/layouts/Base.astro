---
// Gabarit commun : <head> partagé, header, menu mobile et footer.
// Chaque page fournit ses balises meta (slot "head"), ses styles
// (slot "styles"), son contenu (slot par défaut) et ses scripts
// (slot "scripts", inséré après le footer comme à l'origine).
//
// Multilingue : tout vit sur chaparral-finance.com — anglais à la racine,
// français sous /fr, italien sous /it. Le domaine .fr est une simple
// redirection 308 vers .com/fr/… (vercel.json). `path` est le chemin
// canonique de la page hors préfixe de langue (ex. "/transactions").
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';

const { current, bodyClass, locale = 'fr', path = '/' } = Astro.props;

const EN_HOST = 'https://www.chaparral-finance.com';
const prefix = (p) => (path === '/' ? `/${p}` : `/${p}${path}`);
---
<html lang={locale}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta property="og:locale" content={{ fr: 'fr_FR', en: 'en_US', it: 'it_IT' }[locale]}>
  <meta property="og:site_name" content="Chaparral Finance">
  <link rel="alternate" hreflang="fr" href={EN_HOST + prefix('fr')}>
  <link rel="alternate" hreflang="en" href={EN_HOST + path}>
  <link rel="alternate" hreflang="it" href={EN_HOST + prefix('it')}>
  <link rel="alternate" hreflang="x-default" href={EN_HOST + path}>
  <slot name="head" />

  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="48x48">
  <link rel="icon" type="image/svg+xml" href="https://res.cloudinary.com/drncmlu30/image/upload/v1766651131/Favicon_ttv2uq.svg">
  <link rel="icon" type="image/png" sizes="96x96" href="https://res.cloudinary.com/drncmlu30/image/upload/w_96,h_96,c_fill,f_png/v1766651131/Favicon_ttv2uq.png">
  <link rel="icon" type="image/png" sizes="32x32" href="https://res.cloudinary.com/drncmlu30/image/upload/w_32,h_32,c_fill,f_png/v1766651131/Favicon_ttv2uq.png">
  <link rel="apple-touch-icon" sizes="180x180" href="https://res.cloudinary.com/drncmlu30/image/upload/w_180,h_180,c_fill,f_png/v1766651131/Favicon_ttv2uq.png">

  <!-- Choix de langue explicite : ?lang=en pose un cookie qui neutralise la
       géo-redirection France → /fr (règle "missing" dans vercel.json),
       puis nettoie l'URL. -->
  <script is:inline>
    (function () {
      var m = location.search.match(/[?&]lang=en\b/);
      if (m) {
        document.cookie = 'lang_pref=en;path=/;max-age=31536000;samesite=lax';
        var u = new URL(location.href);
        u.searchParams.delete('lang');
        history.replaceState(null, '', u);
      }
    })();
  </script>

  <link rel="stylesheet" href="/assets/styles.css">
  <script is:inline src="https://unpkg.com/lucide@1.17.0/dist/umd/lucide.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://res.cloudinary.com">
  <link rel="preconnect" href="https://ik.imagekit.io">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  <slot name="styles" />
</head>
<body class={bodyClass}>
  <!-- Page Transition Overlay -->
  <div id="page-transition-overlay"></div>

  <!-- Navigation Bar -->
  <Header current={current} locale={locale} path={path} />

  <!-- Mobile Menu Overlay -->
  <MobileMenu current={current} locale={locale} path={path} />

  <slot />

  <Footer current={current} locale={locale} />
  <slot name="scripts" />
</body>
</html>
